# CainoChat Environment Configuration
# Copy this file to .env and fill in your values

# Signaling Server
SIGNALING_SERVER_URL=ws://localhost:8081
SIGNALING_SERVER_PORT=8081

# Firebase (for real OTP - replace with your config)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# TURN/STUN Servers (for NAT traversal in production)
STUN_SERVER=stun:stun.l.google.com:19302
TURN_SERVER=turn:your-turn-server.com:3478
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential

# App Config
APP_NAME=CainoChat
APP_URL=https://cainochat.app
INSTALL_URL=https://cainochat.app/install

# Features
ENABLE_GROUP_CALLS=true
ENABLE_SCREEN_SHARE=true
FREE_TIER_MAX_DURATION=1800
PREMIUM_PRICE=4.99
